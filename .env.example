# ─────────────────────────────────────────
# 뮤지컬 애니메이션 파이프라인 환경변수 설정
# 이 파일을 복사해서 .env 로 저장 후 값을 채워주세요
# cp .env.example .env
# ─────────────────────────────────────────

# [1] Anthropic Claude API
# 발급: https://console.anthropic.com/ → API Keys → Create Key
# 형식: sk-ant-api03-...
ANTHROPIC_API_KEY=

# [2] Suno AI (비공식 쿠키 방식)
# 발급: https://suno.com 로그인 후 개발자도구(F12) → Application → Cookies
#        __client 와 __session 값을 복사하여 아래 형식으로 입력
# 형식: __client=xxxxx; __session=xxxxx
SUNO_COOKIE=
# gcui-art/suno-api 도커 래퍼 로컬 URL (기본값 사용 권장)
SUNO_API_BASE_URL=http://localhost:3000

# [3] Google Gemini API (이미지 생성)
# 발급: https://aistudio.google.com/ → Get API key → Create API key
# 형식: AIzaSy...
GEMINI_API_KEY=

# ─────────────────────────────────────────
# 앱 설정 (변경 불필요)
# ─────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
STORAGE_BASE_PATH=./storage
